#!/bin/bash

# ===================================================================================== #
# Description:		Parses commands to manage task lists.
# Synopsis:			bin/todo <command> [<args>]
# ===================================================================================== #



# Global variables
# ===================================================================================== #

readonly BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

declare -grx APP_ROOT="$(cd "${BIN_DIR}/.." && pwd)"
declare -grx DATA_DIR="${APP_ROOT}/txt"
declare -grx TODO_TXT="${DATA_DIR}/todo.txt"



# Main logic
# ===================================================================================== #

execute_subcommand() {
	local subcommand="$1"
	local script="${APP_ROOT}/src/${subcommand}"

	if [[ -f "$script" ]]
	then
		shift
		source "$script" "$@"

	else
		echo "error: '${subcommand}': command not found"
		exit 1
	fi
}

usage() {
	cat << EOF

USAGE
  bin/todo <command> [<args>]

COMMANDS
  add <task-name> [+ <task-name> ...]
  list [<list-name>[=<number-limit>] ...]
  done <task-number> ...
  undo <task-number> ...
  delete [<list-name>] <task-number> ...
  edit <task-number> <new-name>

EOF
	exit 0
}



# Point of entry
# ===================================================================================== #

case $1 in
	""|help)	usage ;;
	*)			execute_subcommand "$@" ;;
esac
