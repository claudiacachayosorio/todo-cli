#!/bin/bash

# ===================================================================================== #
# Description:		Prints list of tasks.
# Synopsis:			bin/todo list [<list-name>][=<number-limit>] ...
# ===================================================================================== #



# Settings
# ===================================================================================== #

# Extended globbing
shopt -s extglob



# Main logic
# ===================================================================================== #

print_list() {
	# If an argument is missing
	if [[ -z $1 || -z $2 ]]
	then
		return 1
	fi

	# Arguments
	local option_str=$1
	local list_title=$2
	# Metadata variables
	local list_length
	local list_name
	local file_path
	local file_lengthS
	# Output variables
	local header
	local file_output

	# Options from input
	list_name=$(tr -d '=0-9' <<< $option_str)
	list_length=$(tr -d 'a-z=' <<< $option_str)

	# File metadata
	file_path="${DATA_DIR}/${list_name}.txt"
	file_length=$(wc -l < $file_path)

	# Get list from file
	file_output=$(cat -n "$file_path")

	# If list length encompasses entire file
	if [[ $list_length -ge $file_length ]]
	then
		list_length=""
	fi

	case $list_length in
		# If no length input
		"")
			header="$list_title - ALL"
			;;

		# If length is specified
		+([0-9]))
			header="$list_title - $list_length LATEST"
			file_output=$(tail -n "$list_length" <<< "$file_output")
			;;

		# Invalid input
		*)
			echo "error: '$list_length' is not an integer"
			return 1
			;;
	esac

	# Formatted output
	if [[ -n $file_output && -n $header ]]
	then
		cat <<- EOF

		$header

		$file_output

		EOF
	fi
}

list_tasks() {
	# Default options
	if [[ $# -eq 0 ]]
	then
		set -- "$@" "todo"
	fi

	# Parse options
	while [[ $# -gt 0 ]]
	do
		case "$1" in
			# List from todo.txt
			todo|todo=*)
				local list_title="TASKS TO DO"
				print_list "$1" "$list_title"
				shift
				;;

			# List from done.txt
			done|done=*)
				local list_title="TASKS DONE"
				print_list "$1" "$list_title"
				shift
				;;

			# Invalid option
			*)
				echo "error: '$1': invalid argument"
				return 1
				;;
		esac
	done
}



# Point of entry
# ===================================================================================== #

list_tasks "$@"
